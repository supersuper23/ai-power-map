{source:"Sam Altman",target:"OpenAI",type:"leads",label:"CEO"},{source:"Elon Musk",target:"xAI",type:"leads",label:"CEO"},{source:"Elon Musk",target:"Tesla",type:"leads",label:"CEO"},{source:"Demis Hassabis",target:"DeepMind",type:"leads",label:"CEO"},{source:"Jensen Huang",target:"NVIDIA",type:"leads",label:"CEO"},{source:"Satya Nadella",target:"Microsoft",type:"leads",label:"CEO"},{source:"Yann LeCun",target:"Meta",type:"leads",label:"Chief AI Scientist"},{source:"Mark Zuckerberg",target:"Meta",type:"leads",label:"CEO"},{source:"Sundar Pichai",target:"Alphabet",type:"leads",label:"CEO"},{source:"Lisa Su",target:"AMD",type:"leads",label:"CEO"},{source:"Alexandr Wang",target:"ScaleAI",type:"leads",label:"CEO"},{source:"Aidan Gomez",target:"Cohere",type:"leads",label:"CEO"},{source:"Jeff Dean",target:"Alphabet",type:"leads",label:"Chief Scientist"},{source:"Tim Cook",target:"Apple",type:"leads",label:"CEO"},{source:"Arvind Krishna",target:"IBM",type:"leads",label:"CEO"},{source:"Fei-Fei Li",target:"World Labs",type:"leads",label:"Founder"},{source:"Ilya Sutskever",target:"SSI",type:"leads",label:"Founder"},
{source:"Microsoft",target:"OpenAI",type:"funding",label:"$13B+ invested"},{source:"Amazon",target:"Anthropic",type:"funding",label:"$4B invested"},{source:"Alphabet",target:"Anthropic",type:"funding",label:"$2B invested"},{source:"Alphabet",target:"DeepMind",type:"funding",label:"Owns ($500M acq)"},
{source:"NVIDIA",target:"OpenAI",type:"compute",label:"H100/B200 GPUs"},{source:"NVIDIA",target:"xAI",type:"compute",label:"100K+ H100s"},{source:"NVIDIA",target:"Anthropic",type:"compute",label:"GPUs"},{source:"NVIDIA",target:"DeepMind",type:"compute",label:"GPUs"},{source:"NVIDIA",target:"Meta",type:"compute",label:"350K+ H100s"},{source:"NVIDIA",target:"Mistral",type:"compute",label:"GPUs"},{source:"NVIDIA",target:"Tesla",type:"compute",label:"FSD training"},{source:"NVIDIA",target:"Bytedance",type:"compute",label:"GPUs (export limited)"},{source:"NVIDIA",target:"Databricks",type:"compute",label:"GPUs"},{source:"TSMC",target:"NVIDIA",type:"compute",label:"Fabs ALL GPU chips"},{source:"TSMC",target:"AMD",type:"compute",label:"Fabs MI300X"},{source:"TSMC",target:"Apple",type:"compute",label:"Fabs M/A-series"},{source:"TSMC",target:"Broadcom",type:"compute",label:"Fabs custom ASICs"},{source:"AMD",target:"Microsoft",type:"compute",label:"MI300X for Azure"},{source:"AMD",target:"Meta",type:"compute",label:"MI300X diversifying"},{source:"Broadcom",target:"Alphabet",type:"compute",label:"Co-designs Google TPUs"},
{source:"OpenAI",target:"Anthropic",type:"talent",label:"Dario+Daniela+John+team"},{source:"OpenAI",target:"SSI",type:"talent",label:"Ilya Sutskever"},{source:"Inflection",target:"Microsoft",type:"talent",label:"Suleyman+team"},{source:"OpenAI",target:"Andrej Karpathy",type:"talent",label:"Departed"},{source:"Andrej Karpathy",target:"Tesla",type:"talent",label:"Ex-AI Director"},{source:"CharacterAI",target:"Alphabet",type:"talent",label:"Noam Shazeer returned"},{source:"Adept",target:"Amazon",type:"talent",label:"Team acqui-hired"},{source:"DeepMind",target:"xAI",type:"talent",label:"Researchers hired"},
{source:"Meta",target:"HuggingFace",type:"partnership",label:"LLaMA hosting"},{source:"Apple",target:"OpenAI",type:"partnership",label:"ChatGPT in Siri/iOS"},{source:"Microsoft",target:"Mistral",type:"partnership",label:"Azure partnership"},{source:"NVIDIA",target:"Databricks",type:"partnership",label:"AI infrastructure"},{source:"Amazon",target:"Cohere",type:"partnership",label:"Bedrock partner"},{source:"Palantir",target:"OpenAI",type:"partnership",label:"AIP integration"},{source:"Palantir",target:"Anthropic",type:"partnership",label:"AIP integration"},{source:"Alphabet",target:"HuggingFace",type:"partnership",label:"Cloud partnership"},
{source:"ScaleAI",target:"OpenAI",type:"product",label:"Training data"},{source:"ScaleAI",target:"Meta",type:"product",label:"Training data"},{source:"Perplexity",target:"Alphabet",type:"product",label:"Disrupting Search"},{source:"Cursor",target:"Microsoft",type:"product",label:"Challenging Copilot"}];

const typeColors={"s-company":"#ff6b35","startup":"#f5a623","other-company":"#b537f2","s-person":"#4fc3f7","a-person":"#4fc3f7","bc-person":"#81c784"};
const edgeColors={"leads":"#555","funding":"#4a90d9","compute":"#66bb6a","talent":"#ef5350","partnership":"#ce93d8","product":"#ffb74d"};

function nodeRadius(d){if(d.mcap>0){const b=Math.sqrt(d.mcap)*0.55;return Math.max(8,Math.min(b,42));}if(d.tier==="S")return 16;if(d.tier==="A")return 11;return 8;}

const width=window.innerWidth,height=window.innerHeight;
const svg=d3.select("#graph").attr("width",width).attr("height",height);
const defs=svg.append("defs");
const glow=defs.append("filter").attr("id","glow").attr("x","-50%").attr("y","-50%").attr("width","200%").attr("height","200%");
glow.append("feGaussianBlur").attr("stdDeviation","4").attr("result","blur");
const fm=glow.append("feMerge");fm.append("feMergeNode").attr("in","blur");fm.append("feMergeNode").attr("in","SourceGraphic");
Object.entries(edgeColors).forEach(([t,c])=>{defs.append("marker").attr("id","arr-"+t).attr("viewBox","0 0 10 10").attr("refX",20).attr("refY",5).attr("markerWidth",5).attr("markerHeight",5).attr("orient","auto").append("path").attr("d","M 0 0 L 10 5 L 0 10 z").attr("fill",c).attr("opacity",0.5);});

const g=svg.append("g");
const zoom=d3.zoom().scaleExtent([0.1,5]).on("zoom",e=>g.attr("transform",e.transform));
svg.call(zoom);

const simulation=d3.forceSimulation(nodes)
.force("link",d3.forceLink(links).id(d=>d.id).distance(d=>{if(d.type==="leads")return 50;if(d.type==="compute"||d.type==="funding")return 180;return 140;}).strength(d=>d.type==="leads"?1.5:0.3))
.force("charge",d3.forceManyBody().strength(d=>-nodeRadius(d)*25))
.force("center",d3.forceCenter(width/2,height/2))
.force("collision",d3.forceCollide().radius(d=>nodeRadius(d)+6))
.force("x",d3.forceX(width/2).strength(0.02))
.force("y",d3.forceY(height/2).strength(0.02));

const link=g.append("g").selectAll("line").data(links).join("line")
.attr("stroke",d=>edgeColors[d.type]||"#444")
.attr("stroke-width",d=>(d.type==="funding"||d.type==="compute")?1.5:0.8)
.attr("stroke-opacity",0.25)
.attr("stroke-dasharray",d=>d.type==="talent"?"5,3":d.type==="product"?"2,2":"none")
.attr("marker-end",d=>"url(#arr-"+d.type+")");

const linkLabel=g.append("g").selectAll("text").data(links).join("text")
.text(d=>d.label).attr("font-size",6).attr("fill",d=>edgeColors[d.type]||"#444")
.attr("opacity",0).attr("text-anchor","middle").attr("font-family","'JetBrains Mono',monospace");

const node=g.append("g").selectAll("g").data(nodes).join("g")
.call(d3.drag().on("start",ds).on("drag",dr).on("end",de));

node.append("circle").attr("r",d=>nodeRadius(d))
.attr("fill",d=>typeColors[d.type]||"#666")
.attr("stroke",d=>d.tier==="S"?"rgba(255,255,255,0.3)":"none")
.attr("stroke-width",d=>d.tier==="S"?1.5:0)
.attr("opacity",0.85)
.style("filter",d=>d.type==="s-company"&&d.mcap>500?"url(#glow)":"none")
.style("cursor","pointer");

node.filter(d=>d.mcap>=100&&d.type.includes("company")).append("text")
.text(d=>d.mcap>=1000?"$"+(d.mcap/1000).toFixed(1)+"T":"$"+d.mcap+"B")
.attr("text-anchor","middle").attr("dy","0.35em")
.attr("font-size",d=>Math.max(7,nodeRadius(d)*0.3))
.attr("fill","rgba(255,255,255,0.7)")
.attr("font-family","'JetBrains Mono',monospace").attr("font-weight","700")
.style("pointer-events","none");

const labels=node.append("text").text(d=>d.label).attr("text-anchor","middle")
.attr("dy",d=>nodeRadius(d)+11)
.attr("font-size",d=>d.type==="s-company"?9:d.tier==="S"?8:7)
.attr("font-weight",d=>d.tier==="S"?"700":"400")
.attr("fill","#aaa").attr("font-family","'JetBrains Mono',monospace")
.style("pointer-events","none");

const tooltip=d3.select("#tooltip");
node.on("mouseover",function(event,d){
tooltip.style("display","block").html('<div class="tt-name">'+d.label+'</div><div class="tt-sub">'+d.role+'</div><div class="tt-click">▸ Click for full details</div>');
d3.select(this).select("circle").transition().duration(150).attr("r",nodeRadius(d)*1.15).attr("opacity",1);
const conn=new Set([d.id]);links.forEach(l=>{if(l.source.id===d.id)conn.add(l.target.id);if(l.target.id===d.id)conn.add(l.source.id);});
link.attr("stroke-opacity",l=>(l.source.id===d.id||l.target.id===d.id)?0.8:0.04).attr("stroke-width",l=>(l.source.id===d.id||l.target.id===d.id)?2.5:0.3);
linkLabel.attr("opacity",l=>(l.source.id===d.id||l.target.id===d.id)?1:0);
node.select("circle").attr("opacity",n=>conn.has(n.id)?1:0.1);
labels.attr("opacity",n=>conn.has(n.id)?1:0.08);
}).on("mousemove",function(event){tooltip.style("left",(event.clientX+14)+"px").style("top",(event.clientY-8)+"px");
}).on("mouseout",function(){tooltip.style("display","none");
node.select("circle").transition().duration(150).attr("r",d=>nodeRadius(d)).attr("opacity",0.85);
link.attr("stroke-opacity",0.25).attr("stroke-width",d=>(d.type==="funding"||d.type==="compute")?1.5:0.8);
linkLabel.attr("opacity",0);labels.attr("opacity",1);});

node.on("click",function(event,d){
event.stopPropagation();
const panel=document.getElementById("detail-panel");
const pc=document.getElementById("panel-photo-container");
const color=typeColors[d.type]||"#888";
if(d.img){pc.innerHTML='<img class="panel-photo '+(d.type.includes("company")||d.type==="startup"?"company":"")+'" src="'+d.img+'" onerror="this.outerHTML=\'<div class=panel-initials style=background:'+color+'>'+d.label.split(" ").map(w=>w[0]).join("").slice(0,2)+'</div>\'">';}
else{const ini=d.label.split(" ").map(w=>w[0]).join("").slice(0,2);pc.innerHTML='<div class="panel-initials '+(d.type.includes("company")||d.type==="startup"?"company":"")+'" style="background:'+color+'">'+ini+'</div>';}
document.getElementById("panel-name").textContent=d.label;
document.getElementById("panel-role").textContent=d.role||"";
const te=document.getElementById("panel-tier");te.textContent=d.tier+"-Tier";te.style.background=color+"22";te.style.color=color;
const me=document.getElementById("panel-mcap");
if(d.mcap>0){me.textContent=d.mcap>=1000?"Market Cap: ~$"+(d.mcap/1000).toFixed(1)+"T":"Valuation: ~$"+d.mcap+"B";me.style.display="block";}else{me.style.display="none";}
document.getElementById("panel-why").innerHTML=d.why||"";
document.getElementById("panel-facts").innerHTML=d.facts||"";
const cl=document.getElementById("panel-connections");cl.innerHTML="";
links.forEach(l=>{const s=typeof l.source==="object"?l.source.id:l.source;const t=typeof l.target==="object"?l.target.id:l.target;
if(s===d.id||t===d.id){const o=s===d.id?t:s;const dir=s===d.id?"→":"←";const ec=edgeColors[l.type]||"#666";
const li=document.createElement("li");li.innerHTML='<span class="conn-type" style="background:'+ec+'22;color:'+ec+'">'+l.type+'</span> '+dir+' <strong>'+o+'</strong>: '+l.label;cl.appendChild(li);}});
document.getElementById("panel-tags").innerHTML=(d.tags||[]).map(t=>'<span class="panel-tag">'+t+'</span>').join("");
panel.classList.add("open");});

svg.on("click",()=>closePanel());
function closePanel(){document.getElementById("detail-panel").classList.remove("open");}

simulation.on("tick",()=>{
link.attr("x1",d=>d.source.x).attr("y1",d=>d.source.y).attr("x2",d=>d.target.x).attr("y2",d=>d.target.y);
linkLabel.attr("x",d=>(d.source.x+d.target.x)/2).attr("y",d=>(d.source.y+d.target.y)/2);
node.attr("transform",d=>"translate("+d.x+","+d.y+")");});

function ds(e,d){if(!e.active)simulation.alphaTarget(0.3).restart();d.fx=d.x;d.fy=d.y;}
function dr(e,d){d.fx=e.x;d.fy=e.y;}
function de(e,d){if(!e.active)simulation.alphaTarget(0);d.fx=null;d.fy=null;}
function resetZoom(){svg.transition().duration(600).call(zoom.transform,d3.zoomIdentity);}
let labelsOn=true;function toggleLabels(){labelsOn=!labelsOn;labels.style("display",labelsOn?"block":"none");document.getElementById("btn-labels").textContent="Labels: "+(labelsOn?"On":"Off");document.getElementById("btn-labels").classList.toggle("active",!labelsOn);}
let edgesOn=true;function toggleEdges(){edgesOn=!edgesOn;link.style("display",edgesOn?"block":"none");linkLabel.style("display",edgesOn?"block":"none");document.getElementById("btn-edges").textContent="Edges: "+(edgesOn?"On":"Off");document.getElementById("btn-edges").classList.toggle("active",!edgesOn);}
const tiers=["All","S","A","B"];let tierIdx=0;
function cycleTierFilter(){tierIdx=(tierIdx+1)%tiers.length;const t=tiers[tierIdx];document.getElementById("btn-tier").textContent=t==="All"?"All Tiers":t+"-Tier Only";document.getElementById("btn-tier").classList.toggle("active",t!=="All");node.style("display",d=>(t==="All"||d.tier===t)?"block":"none");link.style("display",l=>{if(!edgesOn)return"none";if(t==="All")return"block";const sT=(typeof l.source==="object"?l.source:nodes.find(n=>n.id===l.source))?.tier;const tT=(typeof l.target==="object"?l.target:nodes.find(n=>n.id===l.target))?.tier;return(sT===t||tT===t)?"block":"none";});}
document.getElementById("search").addEventListener("input",function(){const q=this.value.toLowerCase().trim();if(!q){node.select("circle").attr("opacity",0.85);labels.attr("opacity",1);link.attr("stroke-opacity",0.25);return;}const m=new Set();nodes.forEach(n=>{if(n.label.toLowerCase().includes(q)||n.id.toLowerCase().includes(q)||(n.tags||[]).some(t=>t.toLowerCase().includes(q))||(n.role||"").toLowerCase().includes(q))m.add(n.id);});node.select("circle").attr("opacity",n=>m.has(n.id)?1:0.06);labels.attr("opacity",n=>m.has(n.id)?1:0.04);});
document.getElementById("node-count").textContent=nodes.length+" nodes · "+links.length+" connections";
setTimeout(()=>{svg.transition().duration(1000).call(zoom.transform,d3.zoomIdentity.translate(width*0.05,height*0.05).scale(0.75));},2000);
</script>
</body>
